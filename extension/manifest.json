{
	"manifest_version": 3,
	"name": "Whats GPU",
	"version": "1.1.0",
	"description": "Transcreve áudios do WhatsApp Web localmente usando GPU NVIDIA",
	"icons": {
		"38": "icons/38.png",
		"64": "icons/64.png",
		"128": "icons/128.png"
	},

	"action": {
		"default_popup": "popup.html",
		"default_title": "Whats GPU"
	},

	"content_scripts": [
		{
			"matches": ["https://web.whatsapp.com/*"],
			"js": ["content.js"]
		},
		{
			"matches": ["https://web.whatsapp.com/*"],
			"js": ["page.js"],
			"world": "MAIN"
		}
	],

	"background": {
		"service_worker": "service_worker.js"
	},

	"permissions": ["storage"],
	"host_permissions": ["http://localhost:8765/*"]
}
